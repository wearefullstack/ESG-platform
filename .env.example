# ESG Platform Environment Variables

# Flask Configuration
FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_DEBUG=1

# Database
DATABASE_URL=postgresql://esg_user:esg_password@postgres:5432/esg_platform
DB_HOST=postgres
DB_PORT=5432
DB_NAME=esg_platform
DB_USER=esg_user
DB_PASSWORD=esg_password

# Redis
REDIS_URL=redis://redis:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=True

# Security
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-key-change-in-production

# CORS
CORS_ORIGINS=*

# Frontend
VITE_API_URL=http://localhost/api
NODE_ENV=development

# Features
ENABLE_FILE_UPLOADS=true
ENABLE_API_INTEGRATION=true
ENABLE_POWER_BI=false

# Email (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@esg-platform.local

# AI/LLM (optional)
ANTHROPIC_API_KEY=
ENABLE_AI_INSIGHTS=false
